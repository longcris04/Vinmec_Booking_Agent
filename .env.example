# ============================================================
# Vinmec ReAct Agent — Environment Configuration
# Sao chép file này thành .env rồi điền API key tương ứng
# ============================================================

# Provider đang dùng: openai | google | openrouter | local
DEFAULT_PROVIDER=openrouter

# ------------------------------------------------------------
# GOOGLE GEMINI
# Lấy key tại: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# OPENAI
# Lấy key tại: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
DEFAULT_MODEL=gpt-4o

# ------------------------------------------------------------
# OPENROUTER (nhiều model, 1 API key)
# Lấy key tại: https://openrouter.ai/keys
# Danh sách model: https://openrouter.ai/models
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# ------------------------------------------------------------
# LOCAL LLM via Ollama (không cần API key)
# Cài Ollama: https://ollama.com/download
# Pull model:  ollama pull llama3.1:8b
# ------------------------------------------------------------
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_LEVEL=INFO
